<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.smartclaw.schedule.beads-conflict-resolver</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${HOME}/.smartclaw/scripts/beads-conflict-resolver.launchd.sh</string>
    </array>

    <key>RunAtLoad</key>
    <false/>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>${HOME}/.smartclaw/logs/beads-conflict-resolver.log</string>

    <key>StandardErrorPath</key>
    <string>${HOME}/.smartclaw/logs/beads-conflict-resolver.error.log</string>

    <key>WorkingDirectory</key>
    <string>${HOME}/.smartclaw</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>

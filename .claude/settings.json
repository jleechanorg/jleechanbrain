{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "AO_HOOK_EVENT_NAME='PreToolUse' '.claude/metadata-updater.sh'",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "AO_HOOK_EVENT_NAME='PostToolUse' '.claude/metadata-updater.sh'",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
